<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.SuiviScolaire"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">

        <!--
            usesCleartextTraffic="true" permet les appels http:// (non chiffrés)
            vers ton serveur Laravel local pendant le développement.
            Retire cet attribut (et utilise https://) pour une mise en production.
        -->

        <activity
            android:name=".ui.login.LoginActivity"
            android:exported="true"
            android:theme="@style/Theme.SuiviScolaire.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.main.MainActivity"
            android:exported="false"
            android:theme="@style/Theme.SuiviScolaire.NoActionBar" />

        <activity
            android:name=".ui.settings.ChangePasswordActivity"
            android:exported="false"
            android:label="@string/title_change_password"
            android:parentActivityName=".ui.main.MainActivity" />

        <activity
            android:name=".ui.pdf.PdfViewerActivity"
            android:exported="false"
            android:theme="@style/Theme.SuiviScolaire.NoActionBar"
            android:parentActivityName=".ui.main.MainActivity" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>
